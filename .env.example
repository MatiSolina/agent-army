# Copy to .env.local and fill in. Never commit real values — .env*.local is gitignored.
#
# Two steps. STEP 1 is all you need to boot, log in, and run the migration.
# Everything under STEP 2 is optional — add it later (mostly from inside the app),
# only when you actually Deploy an agent or wire up a channel. Leaving STEP 2 blank
# does NOT break local dev.

# ============================================================
# STEP 1 — Required to boot + log in + migrate
# (If you connect the Supabase integration, most of these auto-fill.)
# ============================================================

# --- Database (Supabase Postgres) ---
# Pooler connection string (app runtime). Direct connection (migrations / drizzle-kit push).
DATABASE_URL=
DIRECT_URL=

# --- Supabase Auth / client ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Access gate ---
# The only email allowed past the Supabase Auth login. Create this user in
# Supabase → Authentication → Users after the first boot.
FLEET_OPERATOR_EMAIL=

# --- App URL ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# STEP 2 — Optional, add later (leave blank to boot locally)
# ============================================================

# --- AI Gateway (dashboard playground / Test flow) ---
# On Vercel this is OIDC-injected; set it locally only if you use the Test tab.
# AI_GATEWAY_API_KEY=

# --- Vercel deploy (only needed to ship agents via the Deploy button) ---
# VERCEL_TOKEN=
# VERCEL_ACCESS_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_TEAM_SLUG=   # optional: team slug for the "Open in Vercel" deep-link

# --- Fleet runtime secrets (needed at Deploy time; generate: openssl rand -base64 32) ---
# FLEET_ENCRYPTION_KEY=
# EVE_API_SECRET=
# FM_AGENT_KEY=   # NEVER bake this into an agent project

# --- Kapso / WhatsApp channel (only if you wire up WhatsApp) ---
# KAPSO_API_KEY=
# KAPSO_PLATFORM_API_KEY=
# KAPSO_BASE_URL=
# KAPSO_PHONE_NUMBER_ID=
# KAPSO_WEBHOOK_SECRET=
