# Copy to .env.local and fill in. Never commit real values — .env*.local is gitignored.

# --- Database (Supabase Postgres) ---
# Pooler connection string (used by the app at runtime).
DATABASE_URL=
# Direct (non-pooler) connection, used by some migration scripts.
DIRECT_URL=

# --- Supabase Auth / client ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Access gate ---
# The only email allowed past the Supabase Auth login.
FLEET_OPERATOR_EMAIL=

# --- App URL ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI Gateway ---
# On Vercel this is OIDC-injected; set it locally for the playground/Test flow.
AI_GATEWAY_API_KEY=

# --- Vercel deploy (required for the Deploy button) ---
VERCEL_TOKEN=
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID=
# Optional: team URL slug for the per-agent "Open in Vercel" deep-link.
VERCEL_TEAM_SLUG=

# --- Fleet runtime secrets ---
# Used to sign/encrypt fleet artifacts; generate a random 32+ char value.
FLEET_ENCRYPTION_KEY=
# Shared secret for the FM->agent direction (the agent's eve channel checks it).
EVE_API_SECRET=
# FM-only HMAC key for per-agent agent->FM tokens (runtime-config + token broker).
# Generate: openssl rand -base64 32. NEVER bake this into an agent project.
FM_AGENT_KEY=

# --- Kapso / WhatsApp channel (optional) ---
KAPSO_API_KEY=
KAPSO_PLATFORM_API_KEY=
KAPSO_BASE_URL=
KAPSO_PHONE_NUMBER_ID=
KAPSO_WEBHOOK_SECRET=
